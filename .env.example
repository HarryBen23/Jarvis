# Configuration JARVIS

# API OpenAI (obtenir depuis https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token Home Assistant (obtenir depuis Settings > Devices & Services > API Tokens)
HA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URLs
HA_URL=http://home-assistant:8123

# Configuration audio
AUDIO_DEVICE_INDEX=
SAMPLE_RATE=16000

# Mot de réveil
WAKE_WORD=jarvis

# Logging
LOG_LEVEL=INFO
